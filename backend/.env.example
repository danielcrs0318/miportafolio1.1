# ============================================================
# .env.example — Variables de entorno para el backend
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# Puerto del servidor API (Render lo asigna automáticamente)
PORT=4000

# Entorno
NODE_ENV=development

# Gmail — Para Nodemailer
# Usa un "App Password" de Google (no tu contraseña real)
# Ve a: https://myaccount.google.com/apppasswords
# Nota: puedes pegar la contraseña con o sin espacios
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu_app_password_de_gmail

# Orígenes permitidos para CORS (separados por coma)
# En producción incluye tu dominio de Vercel y dominio personalizado
FRONTEND_URL=https://danielmolina.dev,https://www.danielmolina.dev
