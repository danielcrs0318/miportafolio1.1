# ============================================================
# .env.example — Variables de entorno para el backend
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# Puerto del servidor API (Render lo asigna automáticamente)
PORT=4000

# Entorno
NODE_ENV=development

# Gmail — Nodemailer (App Password, NO la contraseña normal)
# https://myaccount.google.com/apppasswords
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu_app_password_de_gmail

# Opcional: bandeja donde recibes los mensajes (por defecto = EMAIL_USER)
# EMAIL_TO=tu-correo@gmail.com

# Orígenes CORS permitidos (separados por coma, SIN barra final)
# Incluye tu dominio de Vercel y el dominio personalizado
FRONTEND_URL=https://danielmolina.dev,https://www.danielmolina.dev,https://tu-proyecto.vercel.app
