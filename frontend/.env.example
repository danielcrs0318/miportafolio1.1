# ============================================================
# .env.example — Variables de entorno para el frontend (Vite)
# Copia este archivo como .env.local para desarrollo local
# En Vercel, configura estas variables en el dashboard (build time)
# ============================================================

# URL del backend API en Render (SIN barra final)
# Desarrollo: http://localhost:4000
# Producción (OBLIGATORIO en Vercel): https://tu-servicio.onrender.com
#
# Si falta en el build de Vercel, el formulario llama a localhost y falla.
VITE_API_URL=http://localhost:4000
